<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Tarea entregable 2 de CSS: header hero estático para GathSession." />
  <title>GathSession | CSS Entregable 2</title>
  <link rel="stylesheet" href="css/styles.css" />
</head>
<body>
  <div class="layout">
    <header class="header">
      <a class="brand" href="#" aria-label="Página principal de GathSession">
        <span class="brand__highlight">Gath</span>Session<span class="brand__highlight">.</span>
      </a>

      <nav class="nav" aria-label="Navegación principal">
        <ul class="nav__list">
          <li><a class="nav__link nav__link--active" href="#">Home</a></li>
          <li><a class="nav__link" href="#">Features</a></li>
          <li><a class="nav__link" href="#">Blog</a></li>
          <li><a class="nav__link" href="#">Contact</a></li>
          <li><a class="nav__link" href="#">About Us</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-heading">
        <div class="hero__info">
          <h1 class="hero__title" id="hero-heading">Build your best community starting from here.</h1>

          <p class="hero__paragraph">
            Meet and communicate with the best people to run projects, events
            or other activities in a more effective and fun way
          </p>

          <div class="hero__buttons">
            <a class="btn btn--primary" href="#">Get Started</a>
            <a class="btn btn--secondary" href="#">Learn More <span aria-hidden="true">→</span></a>
          </div>

          <div class="benefits" aria-label="Características principales">
            <article class="benefit">
              <div class="benefit__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M8 11h7a3 3 0 0 1 0 6h-4" />
                  <path d="M6 8h12" />
                  <path d="M6 17h5" />
                  <path d="M6 8v7a2 2 0 0 0 2 2" />
                  <path d="M5 21h13" />
                </svg>
              </div>
              <p class="benefit__text">Build<br />Community</p>
            </article>

            <article class="benefit">
              <div class="benefit__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <rect x="4" y="5" width="16" height="15" rx="2" />
                  <path d="M8 3v4" />
                  <path d="M16 3v4" />
                  <path d="M4 10h16" />
                  <path d="M8 14h2.5" />
                  <path d="M13.5 14H16" />
                </svg>
              </div>
              <p class="benefit__text">Share<br />Events</p>
            </article>

            <article class="benefit">
              <div class="benefit__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <rect x="4" y="5" width="16" height="14" rx="2" />
                  <circle cx="9" cy="10" r="1.4" />
                  <path d="M6.5 17l4-4 3 3 2-2 3 3" />
                </svg>
              </div>
              <p class="benefit__text">Get<br />Information</p>
            </article>
          </div>
        </div>

        <div class="hero__art" aria-hidden="true">
          <figure class="portrait portrait--main">
            <img src="https://images.unsplash.com/photo-1527980965255-d3b416303d12?auto=format&fit=crop&w=500&q=80" alt="" />
          </figure>

          <figure class="portrait portrait--top">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=500&q=80" alt="" />
          </figure>

          <figure class="portrait portrait--right">
            <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=500&q=80" alt="" />
          </figure>

          <figure class="portrait portrait--center">
            <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&w=500&q=80" alt="" />
          </figure>

          <figure class="portrait portrait--bottom">
            <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=500&q=80" alt="" />
          </figure>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
